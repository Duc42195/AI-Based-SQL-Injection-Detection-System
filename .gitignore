# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Local env / secrets
.env

# Data artifacts (keep dir structure via .gitkeep, ignore contents)
data/**/*.csv
data/**/*.jsonl
data/**/*.db
data/**/*.parquet
data/**/*.txt

# Model binaries (versioned dirs tracked, large weights ignored)
models/**/*.pkl
models/**/*.joblib
models/**/*.bin
models/**/*.pt
models/**/*.safetensors

# Notebook checkpoints
.ipynb_checkpoints/
