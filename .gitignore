# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Local env / secrets
.env

# Data artifacts (keep dir structure via .gitkeep, ignore contents)
data/**/*.csv
data/**/*.jsonl
data/**/*.db
data/**/*.parquet
data/**/*.txt

# Model binaries (versioned dirs tracked via metadata.json, weights ignored)
models/**/*.pkl
models/**/*.joblib
models/**/*.bin
models/**/*.pt
models/**/*.safetensors
models/**/*.json
models/**/*.txt
# Exception: keep the small metadata.json describing each versioned model
!models/**/metadata.json
# Architecture-comparison candidates: track the folder + metadata/vocab/config,
# heavy weights (*.bin/*.pt/*.joblib) stay ignored above and live on HF.

# Notebook checkpoints
.ipynb_checkpoints/
